      "keyPath": "/etc/hyperledger/fabric/manufacturer/keystore"
    },
    "Distributor": {
      "mspId": "DistributorMSP",
      "peerEndpoint": "peer0.distributor.prod.drugguard.vn:7051",
      "peerHostAlias": "peer0.distributor.prod.drugguard.vn",
      "tlsCertPath": "/etc/hyperledger/fabric/distributor/tls/ca.crt",
