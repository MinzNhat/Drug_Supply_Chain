{
  "profile": "prod",
  "channelName": "supplychain-prod",
  "chaincodeName": "drugtracker",
  "publicScanRole": "Regulator",
  "distributorIdentityBridge": {
    "enabled": true,
    "requireUnitForDistributor": true,
    "units": {
      "dist-unit-hcm": {
        "identityLabel": "Distributor Unit HCM",
        "mspId": "DistributorMSP",
        "peerEndpoint": "peer0.distributor.prod.drugguard.vn:7051",
