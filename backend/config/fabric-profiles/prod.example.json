        "tlsCertPath": "/etc/hyperledger/fabric/distributor/tls/ca.crt",
        "certPath": "/etc/hyperledger/fabric/distributor/units/hcm/signcerts/cert.pem",
        "keyPath": "/etc/hyperledger/fabric/distributor/units/hcm/keystore"
      }
    }
  },
  "organizations": {
    "Manufacturer": {
      "mspId": "ManufacturerMSP",
      "peerEndpoint": "peer0.manufacturer.prod.drugguard.vn:7051",
