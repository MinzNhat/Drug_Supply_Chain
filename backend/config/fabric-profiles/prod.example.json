    "Regulator": {
      "mspId": "RegulatorMSP",
      "peerEndpoint": "peer0.regulator.prod.drugguard.vn:7051",
      "peerHostAlias": "peer0.regulator.prod.drugguard.vn",
      "tlsCertPath": "/etc/hyperledger/fabric/regulator/tls/ca.crt",
      "certPath": "/etc/hyperledger/fabric/regulator/signcerts/cert.pem",
      "keyPath": "/etc/hyperledger/fabric/regulator/keystore"
