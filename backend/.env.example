PORT=8090
MONGO_URI=mongodb://mongo:27017
MONGO_DB=drug_guard
QR_SERVICE_URL=http://localhost:8080
JWT_SECRET=dev_local_jwt_secret_min_32_chars
# For container secret mount use JWT_SECRET_FILE instead of JWT_SECRET.
# JWT_SECRET_FILE=/run/secrets/backend_jwt_secret
JWT_EXPIRES_IN=8h
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=10000
AI_VERIFICATION_ENABLED=false
AI_VERIFICATION_URL=http://localhost:8701
AI_VERIFICATION_TIMEOUT_MS=10000
AI_VERIFICATION_FAIL_OPEN=true

# Canonical alert sink delivery (P0-05)
ALERT_SINK_ENABLED=true
ALERT_SINK_TYPE=logger
ALERT_SINK_RETRY_MAX_ATTEMPTS=3
ALERT_SINK_RETRY_BASE_DELAY_MS=200
ALERT_SINK_RETRY_MAX_DELAY_MS=2000
# Required only when ALERT_SINK_TYPE=webhook
ALERT_SINK_WEBHOOK_URL=
ALERT_SINK_WEBHOOK_TIMEOUT_MS=5000
ALERT_SINK_WEBHOOK_AUTH_HEADER=authorization
ALERT_SINK_WEBHOOK_AUTH_TOKEN=

# Fabric gateway switch
FABRIC_ENABLED=true
FABRIC_PROFILE=local
# Optional JSON profile for non-local environments.
# FABRIC_PROFILE_FILE=./config/fabric-profiles/staging.example.json
FABRIC_STRICT_CREDENTIALS=false
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=drugtracker
FABRIC_EVALUATE_TIMEOUT_MS=5000
FABRIC_SUBMIT_TIMEOUT_MS=15000
FABRIC_COMMIT_STATUS_TIMEOUT_MS=20000
FABRIC_EVALUATE_RETRY_MAX_ATTEMPTS=3
FABRIC_EVALUATE_RETRY_BASE_DELAY_MS=200
FABRIC_EVALUATE_RETRY_MAX_DELAY_MS=1000
FABRIC_SUBMIT_RETRY_MAX_ATTEMPTS=1
FABRIC_SUBMIT_RETRY_BASE_DELAY_MS=250
FABRIC_SUBMIT_RETRY_MAX_DELAY_MS=1200
FABRIC_PUBLIC_SCAN_ROLE=Regulator

# Manufacturer identity and peer
FABRIC_MANUFACTURER_MSP_ID=Org2MSP
FABRIC_MANUFACTURER_PEER_ENDPOINT=localhost:9051
FABRIC_MANUFACTURER_PEER_HOST_ALIAS=peer0.org2.example.com
FABRIC_MANUFACTURER_TLS_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/org2.example.com/peers/peer0.org2.example.com/tls/ca.crt
FABRIC_MANUFACTURER_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/org2.example.com/users/User1@org2.example.com/msp/signcerts/User1@org2.example.com-cert.pem
FABRIC_MANUFACTURER_KEY_PATH=../blockchain/test-network/organizations/peerOrganizations/org2.example.com/users/User1@org2.example.com/msp/keystore

# Distributor identity and peer
FABRIC_DISTRIBUTOR_MSP_ID=Org3MSP
FABRIC_DISTRIBUTOR_PEER_ENDPOINT=localhost:11051
FABRIC_DISTRIBUTOR_PEER_HOST_ALIAS=peer0.org3.example.com
FABRIC_DISTRIBUTOR_TLS_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/org3.example.com/peers/peer0.org3.example.com/tls/ca.crt
FABRIC_DISTRIBUTOR_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/org3.example.com/users/User1@org3.example.com/msp/signcerts/User1@org3.example.com-cert.pem
FABRIC_DISTRIBUTOR_KEY_PATH=../blockchain/test-network/organizations/peerOrganizations/org3.example.com/users/User1@org3.example.com/msp/keystore

# Regulator identity and peer
FABRIC_REGULATOR_MSP_ID=Org1MSP
FABRIC_REGULATOR_PEER_ENDPOINT=localhost:7051
FABRIC_REGULATOR_PEER_HOST_ALIAS=peer0.org1.example.com
FABRIC_REGULATOR_TLS_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/org1.example.com/peers/peer0.org1.example.com/tls/ca.crt
FABRIC_REGULATOR_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/org1.example.com/users/User1@org1.example.com/msp/signcerts/User1@org1.example.com-cert.pem
FABRIC_REGULATOR_KEY_PATH=../blockchain/test-network/organizations/peerOrganizations/org1.example.com/users/User1@org1.example.com/msp/keystore
