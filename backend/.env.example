PORT=8090
MONGO_URI=mongodb://mongo:27017
MONGO_DB=drug_guard
QR_SERVICE_URL=http://localhost:8080
JWT_SECRET=dev_local_jwt_secret_min_32_chars
# For container secret mount use JWT_SECRET_FILE instead of JWT_SECRET.
# JWT_SECRET_FILE=/run/secrets/backend_jwt_secret
JWT_EXPIRES_IN=8h
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=10000
# CORS: comma-separated allowed origins. Use * for local dev only.
# Production example: CORS_ALLOWED_ORIGINS=https://drugguard.drugguard.vn
CORS_ALLOWED_ORIGINS=*

AI_VERIFICATION_ENABLED=false
AI_VERIFICATION_PROFILE=local
# Optional JSON profile for AI verification runtime policy.
# AI_VERIFICATION_PROFILE_FILE=./config/ai-profiles/staging.example.json
AI_VERIFICATION_STRICT_CONFIG=false
AI_VERIFICATION_URL=http://localhost:8701
AI_VERIFICATION_TIMEOUT_MS=10000
AI_VERIFICATION_FAIL_OPEN=true
AI_VERIFICATION_OWNER_SERVICE=
AI_VERIFICATION_OWNER_ML=
AI_VERIFICATION_OWNER_ONCALL=
AI_VERIFICATION_RUNBOOK_PATH=docs/platform/ai-verification-operations.md
AI_VERIFICATION_RUNBOOK_ESCALATION=

# Direct document upload/IPFS integration (P1-09)
DOC_UPLOAD_ENABLED=false
DOC_UPLOAD_PROVIDER=mock
DOC_UPLOAD_TIMEOUT_MS=15000
DOC_UPLOAD_MAX_BYTES=5242880
DOC_UPLOAD_REQUIRE_PINNED=true
DOC_UPLOAD_PACKAGE_IMAGE_MEDIA_TYPES=image/jpeg,image/png,image/webp
DOC_UPLOAD_QUALITY_CERT_MEDIA_TYPES=application/pdf,image/jpeg,image/png
# Required when DOC_UPLOAD_PROVIDER=kubo
DOC_UPLOAD_KUBO_API_URL=http://127.0.0.1:5001
DOC_UPLOAD_KUBO_AUTH_TOKEN=
# Required when DOC_UPLOAD_PROVIDER=pinata
DOC_UPLOAD_PINATA_API_URL=https://api.pinata.cloud
DOC_UPLOAD_PINATA_JWT=

# Canonical alert sink delivery (P0-05)
ALERT_SINK_ENABLED=true
ALERT_SINK_TYPE=logger
ALERT_SINK_RETRY_MAX_ATTEMPTS=3
ALERT_SINK_RETRY_BASE_DELAY_MS=200
ALERT_SINK_RETRY_MAX_DELAY_MS=2000
# Required only when ALERT_SINK_TYPE=webhook
ALERT_SINK_WEBHOOK_URL=
ALERT_SINK_WEBHOOK_TIMEOUT_MS=5000
ALERT_SINK_WEBHOOK_AUTH_HEADER=authorization
ALERT_SINK_WEBHOOK_AUTH_TOKEN=

# Fabric gateway switch
FABRIC_ENABLED=true
FABRIC_PROFILE=local
# Optional JSON profile for non-local environments.
# FABRIC_PROFILE_FILE=./config/fabric-profiles/staging.example.json
FABRIC_STRICT_CREDENTIALS=false
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=drugtracker
FABRIC_EVALUATE_TIMEOUT_MS=5000
FABRIC_SUBMIT_TIMEOUT_MS=15000
FABRIC_COMMIT_STATUS_TIMEOUT_MS=20000
FABRIC_EVALUATE_RETRY_MAX_ATTEMPTS=3
FABRIC_EVALUATE_RETRY_BASE_DELAY_MS=200
FABRIC_EVALUATE_RETRY_MAX_DELAY_MS=1000
FABRIC_SUBMIT_RETRY_MAX_ATTEMPTS=1
FABRIC_SUBMIT_RETRY_BASE_DELAY_MS=250
FABRIC_SUBMIT_RETRY_MAX_DELAY_MS=1200
FABRIC_PUBLIC_SCAN_ROLE=Regulator
FABRIC_DISTRIBUTOR_IDENTITY_BRIDGE_ENABLED=false
FABRIC_DISTRIBUTOR_IDENTITY_BRIDGE_REQUIRE_UNIT=true
# JSON object map: unitId -> dedicated distributor Fabric identity
# FABRIC_DISTRIBUTOR_IDENTITY_BRIDGE_UNITS_JSON={"dist-unit-hcm":{"identityLabel":"Distributor Unit HCM","mspId":"DistributorMSP","peerEndpoint":"localhost:11051","peerHostAlias":"peer0.distributor.drugguard.vn","tlsCertPath":"../blockchain/test-network/organizations/peerOrganizations/distributor.drugguard.vn/peers/peer0.distributor.drugguard.vn/tls/ca.crt","certPath":"../blockchain/test-network/organizations/peerOrganizations/distributor.drugguard.vn/users/User1@distributor.drugguard.vn/msp/signcerts/User1@distributor.drugguard.vn-cert.pem","keyPath":"../blockchain/test-network/organizations/peerOrganizations/distributor.drugguard.vn/users/User1@distributor.drugguard.vn/msp/keystore"}}

# Manufacturer identity and peer
FABRIC_MANUFACTURER_MSP_ID=ManufacturerMSP
FABRIC_MANUFACTURER_PEER_ENDPOINT=localhost:9051
FABRIC_MANUFACTURER_PEER_HOST_ALIAS=peer0.manufacturer.drugguard.vn
FABRIC_MANUFACTURER_TLS_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/manufacturer.drugguard.vn/peers/peer0.manufacturer.drugguard.vn/tls/ca.crt
FABRIC_MANUFACTURER_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/manufacturer.drugguard.vn/users/User1@manufacturer.drugguard.vn/msp/signcerts/User1@manufacturer.drugguard.vn-cert.pem
FABRIC_MANUFACTURER_KEY_PATH=../blockchain/test-network/organizations/peerOrganizations/manufacturer.drugguard.vn/users/User1@manufacturer.drugguard.vn/msp/keystore

# Distributor identity and peer
FABRIC_DISTRIBUTOR_MSP_ID=DistributorMSP
FABRIC_DISTRIBUTOR_PEER_ENDPOINT=localhost:11051
FABRIC_DISTRIBUTOR_PEER_HOST_ALIAS=peer0.distributor.drugguard.vn
FABRIC_DISTRIBUTOR_TLS_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/distributor.drugguard.vn/peers/peer0.distributor.drugguard.vn/tls/ca.crt
FABRIC_DISTRIBUTOR_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/distributor.drugguard.vn/users/User1@distributor.drugguard.vn/msp/signcerts/User1@distributor.drugguard.vn-cert.pem
FABRIC_DISTRIBUTOR_KEY_PATH=../blockchain/test-network/organizations/peerOrganizations/distributor.drugguard.vn/users/User1@distributor.drugguard.vn/msp/keystore

# Regulator identity and peer
FABRIC_REGULATOR_MSP_ID=RegulatorMSP
FABRIC_REGULATOR_PEER_ENDPOINT=localhost:7051
FABRIC_REGULATOR_PEER_HOST_ALIAS=peer0.regulator.drugguard.vn
FABRIC_REGULATOR_TLS_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/regulator.drugguard.vn/peers/peer0.regulator.drugguard.vn/tls/ca.crt
FABRIC_REGULATOR_CERT_PATH=../blockchain/test-network/organizations/peerOrganizations/regulator.drugguard.vn/users/User1@regulator.drugguard.vn/msp/signcerts/User1@regulator.drugguard.vn-cert.pem
FABRIC_REGULATOR_KEY_PATH=../blockchain/test-network/organizations/peerOrganizations/regulator.drugguard.vn/users/User1@regulator.drugguard.vn/msp/keystore

# ── Network topology health probe (GET /api/v1/network/topology) ─────────────
# Fabric Operations listener port for peer nodes (default: 9443).
FABRIC_PEER_OPERATIONS_PORT=9443
# Fabric Operations listener port for orderer nodes (default: 8443).
FABRIC_ORDERER_OPERATIONS_PORT=8443
# Per-node probe timeout in milliseconds. Keep short — all probes run in parallel.
FABRIC_NODE_PROBE_TIMEOUT_MS=2000
