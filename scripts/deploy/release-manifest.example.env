# Example staging release manifest.
# Use immutable image digests generated by CI publish stage.

DATN_RELEASE_ID=release-2026-03-30-rc1
DATN_DEPLOY_REGION=vn-south-1
DATN_DATA_RESIDENCY_REGION=vn-south-1
DATN_DR_STRATEGY=warm-standby

DATN_STAGING_QR_PYTHON_IMAGE=ghcr.io/example/datn/qr-python-core@sha256:replace_me
DATN_STAGING_QR_SERVICE_IMAGE=ghcr.io/example/datn/qr-service@sha256:replace_me
DATN_STAGING_AI_PYTHON_IMAGE=ghcr.io/example/datn/ai-python-core@sha256:replace_me
DATN_STAGING_AI_SERVICE_IMAGE=ghcr.io/example/datn/ai-service@sha256:replace_me
DATN_STAGING_BACKEND_IMAGE=ghcr.io/example/datn/backend@sha256:replace_me